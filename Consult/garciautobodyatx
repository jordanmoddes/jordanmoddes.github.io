<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Garcia Auto Repair | Troy, TX | (254) 938-4004</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --red:    #c0200f;
      --red2:   #e02515;
      --dark:   #111111;
      --dark2:  #1a1a1a;
      --dark3:  #222222;
      --gray:   #888;
      --light:  #f4f4f4;
      --white:  #ffffff;
      --border: rgba(255,255,255,0.08);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Barlow', sans-serif;
      background: var(--white);
      color: var(--dark);
      overflow-x: hidden;
    }

    /* ── UTILITY BAR ── */
    .util-bar {
      background: var(--red);
      padding: 9px 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
    }
    .util-left {
      display: flex; gap: 24px; align-items: center; flex-wrap: wrap;
    }
    .util-item {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.92);
    }
    .util-item a { color: inherit; text-decoration: none; }
    .util-item span { opacity: 0.6; margin-right: 6px; }
    .util-demo {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.55);
      text-transform: uppercase;
    }

    /* ── NAV ── */
    nav {
      background: var(--dark);
      padding: 0 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky; top: 0; z-index: 200;
      box-shadow: 0 2px 20px rgba(0,0,0,0.4);
    }
    .nav-logo {
      display: flex; align-items: center; gap: 14px;
      text-decoration: none; padding: 16px 0;
    }
    .nav-logo-icon {
      width: 44px; height: 44px;
      background: var(--red);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
      flex-shrink: 0;
    }
    .nav-logo-text { line-height: 1.15; }
    .nav-logo-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.25rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--white);
    }
    .nav-logo-sub {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--red);
    }
    .nav-links {
      display: flex; list-style: none;
    }
    .nav-links a {
      display: block;
      padding: 22px 16px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      border-bottom: 3px solid transparent;
      margin-bottom: -3px;
      transition: color 0.2s, border-color 0.2s;
    }
    .nav-links a:hover { color: var(--white); border-bottom-color: var(--red); }
    .nav-cta {
      background: var(--red);
      color: var(--white) !important;
      padding: 12px 22px !important;
      margin-left: 16px;
      border-bottom: none !important;
      font-weight: 700 !important;
      letter-spacing: 0.1em !important;
      transition: background 0.2s !important;
    }
    .nav-cta:hover { background: var(--red2) !important; border-bottom: none !important; }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 88vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      background: var(--dark);
    }
    /* Dark gradient bg simulating a shop photo */
    .hero-bg {
      position: absolute; inset: 0;
      background:
        linear-gradient(105deg, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.7) 55%, rgba(0,0,0,0.4) 100%),
        /* Simulated dark shop texture */
        repeating-linear-gradient(
          90deg,
          rgba(255,255,255,0.012) 0px, rgba(255,255,255,0.012) 1px,
          transparent 1px, transparent 80px
        ),
        repeating-linear-gradient(
          0deg,
          rgba(255,255,255,0.012) 0px, rgba(255,255,255,0.012) 1px,
          transparent 1px, transparent 80px
        ),
        radial-gradient(ellipse 120% 100% at 70% 50%, #2a1a1a 0%, #111 60%, #0a0a0a 100%);
    }
    /* Red accent line left edge */
    .hero-accent {
      position: absolute;
      top: 0; left: 0;
      width: 6px; height: 100%;
      background: var(--red);
    }
    /* Diagonal red slash behind content */
    .hero-slash {
      position: absolute;
      right: -80px; top: -10%;
      width: 55%; height: 120%;
      background: linear-gradient(135deg, transparent 48%, rgba(192,32,15,0.06) 48%);
      pointer-events: none;
    }

    .hero-content {
      position: relative; z-index: 2;
      padding: 80px 80px 80px 80px;
      max-width: 720px;
      animation: heroIn 0.8s ease both;
    }
    @keyframes heroIn {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-tag {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--red);
      padding: 6px 16px;
      margin-bottom: 28px;
    }
    .hero-tag-dot { width: 6px; height: 6px; background: var(--white); border-radius: 50%; }
    .hero-tag-text {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--white);
    }
    .hero-h1 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(3.2rem, 7vw, 6rem);
      font-weight: 900;
      line-height: 0.92;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 24px;
    }
    .hero-h1 .red { color: var(--red); }
    .hero-sub {
      font-size: 1.05rem;
      font-weight: 300;
      color: rgba(255,255,255,0.65);
      line-height: 1.7;
      max-width: 480px;
      margin-bottom: 40px;
    }
    .hero-actions {
      display: flex; gap: 14px; flex-wrap: wrap; align-items: center; margin-bottom: 52px;
    }
    .btn-hero-primary {
      background: var(--red);
      color: var(--white);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 16px 36px;
      text-decoration: none;
      display: inline-block;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-hero-primary:hover { background: var(--red2); transform: translateY(-2px); }
    .btn-hero-sec {
      color: var(--white);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 14px 34px;
      text-decoration: none;
      display: inline-block;
      border: 2px solid rgba(255,255,255,0.35);
      transition: border-color 0.2s, background 0.2s;
    }
    .btn-hero-sec:hover { border-color: var(--white); background: rgba(255,255,255,0.06); }

    /* Trust row */
    .hero-trust {
      display: flex; gap: 28px; flex-wrap: wrap; align-items: center;
      border-top: 1px solid rgba(255,255,255,0.1);
      padding-top: 28px;
    }
    .trust-item {
      display: flex; align-items: center; gap: 10px;
    }
    .trust-icon { font-size: 1.3rem; }
    .trust-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55);
    }
    .trust-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem;
      font-weight: 800;
      color: var(--white);
    }

    /* ── PHONE BAND ── */
    .phone-band {
      background: var(--red);
      padding: 20px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }
    .phone-band-left {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.8);
    }
    .phone-band-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 2.2rem;
      font-weight: 900;
      letter-spacing: 0.04em;
      color: var(--white);
      text-decoration: none;
    }
    .phone-band-num:hover { text-decoration: underline; }
    .phone-band-right {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.7);
    }

    /* ── SECTIONS ── */
    section { padding: 88px 40px; }
    .container { max-width: 1100px; margin: 0 auto; }
    .section-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 10px;
    }
    .section-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      color: var(--dark);
      line-height: 1;
      margin-bottom: 16px;
    }
    .section-title.white { color: var(--white); }
    .section-body {
      font-size: 1rem;
      font-weight: 400;
      color: #555;
      line-height: 1.75;
      max-width: 540px;
    }
    .section-body.white { color: rgba(255,255,255,0.65); }
    .title-bar {
      width: 48px; height: 4px;
      background: var(--red);
      margin-bottom: 32px;
    }

    /* ── ABOUT ── */
    #about { background: var(--white); }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: center;
    }
    .about-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      margin-top: 40px;
    }
    .about-stat {
      background: var(--light);
      padding: 24px 20px;
      border-left: 4px solid transparent;
      transition: border-color 0.2s;
    }
    .about-stat:hover { border-left-color: var(--red); }
    .about-stat-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 2.4rem;
      font-weight: 900;
      color: var(--red);
      line-height: 1;
    }
    .about-stat-label {
      font-size: 0.82rem;
      font-weight: 600;
      color: #777;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-top: 4px;
    }
    /* Right panel: Info card */
    .info-card {
      background: var(--dark);
      padding: 0;
      position: relative;
      overflow: hidden;
    }
    .info-card-top {
      background: var(--red);
      padding: 28px 32px;
    }
    .info-card-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.4rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--white);
    }
    .info-card-sub {
      font-size: 0.82rem;
      font-weight: 500;
      color: rgba(255,255,255,0.75);
      margin-top: 4px;
      letter-spacing: 0.06em;
    }
    .info-card-body { padding: 32px; }
    .info-row {
      display: flex; gap: 16px; align-items: flex-start;
      padding: 14px 0;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .info-row:last-child { border-bottom: none; }
    .info-icon { font-size: 1.1rem; margin-top: 2px; flex-shrink: 0; }
    .info-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 3px;
    }
    .info-value {
      font-size: 0.92rem;
      font-weight: 500;
      color: rgba(255,255,255,0.85);
      line-height: 1.55;
    }
    .info-value a { color: var(--white); text-decoration: none; }
    .info-value a:hover { color: var(--red); }

    /* ── SERVICES ── */
    #services { background: var(--dark); padding-bottom: 88px; }
    .services-intro {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: end;
      margin-bottom: 56px;
    }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2px;
    }
    .svc-card {
      background: var(--dark2);
      padding: 32px 24px;
      border-bottom: 3px solid transparent;
      transition: background 0.2s, border-color 0.25s, transform 0.2s;
      cursor: default;
      position: relative;
      overflow: hidden;
    }
    .svc-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: var(--red);
      transform: scaleY(0);
      transform-origin: bottom;
      transition: transform 0.3s ease;
      z-index: 0;
    }
    .svc-card:hover::before { transform: scaleY(1); }
    .svc-card:hover .svc-icon,
    .svc-card:hover .svc-name,
    .svc-card:hover .svc-desc { color: var(--white); position: relative; z-index: 1; }
    .svc-card > * { position: relative; z-index: 1; }
    .svc-icon {
      font-size: 1.8rem;
      margin-bottom: 16px;
      display: block;
      transition: color 0.2s;
    }
    .svc-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--white);
      margin-bottom: 8px;
      transition: color 0.2s;
    }
    .svc-desc {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.45);
      line-height: 1.6;
      transition: color 0.2s;
    }
    .svc-card.featured {
      background: var(--red);
    }
    .svc-card.featured::before { display: none; }
    .svc-card.featured .svc-desc { color: rgba(255,255,255,0.75); }

    /* ── WHY ── */
    #why { background: var(--light); }
    .why-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      margin-top: 52px;
    }
    .why-card {
      background: var(--white);
      padding: 36px 28px;
      border-top: 4px solid transparent;
      transition: border-color 0.2s, transform 0.2s;
    }
    .why-card:hover { border-top-color: var(--red); transform: translateY(-4px); }
    .why-number {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 3.5rem;
      font-weight: 900;
      color: var(--red);
      opacity: 0.12;
      line-height: 1;
      margin-bottom: 12px;
    }
    .why-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.1rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--dark);
      margin-bottom: 10px;
    }
    .why-text {
      font-size: 0.9rem;
      color: #666;
      line-height: 1.7;
    }

    /* ── REVIEWS ── */
    #reviews { background: var(--dark); }
    .reviews-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 48px;
      flex-wrap: wrap;
      gap: 24px;
    }
    .google-badge {
      background: var(--dark2);
      border: 1px solid rgba(255,255,255,0.08);
      padding: 20px 28px;
      text-align: center;
      min-width: 180px;
    }
    .google-score {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 3.8rem;
      font-weight: 900;
      color: var(--white);
      line-height: 1;
    }
    .google-stars { color: #f5a623; font-size: 1.1rem; letter-spacing: 2px; margin: 4px 0; }
    .google-count {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gray);
    }
    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .review-card {
      background: var(--dark2);
      padding: 32px 28px;
      border-top: 3px solid transparent;
      transition: border-color 0.2s;
    }
    .review-card:hover { border-top-color: var(--red); }
    .review-stars { color: #f5a623; font-size: 0.9rem; letter-spacing: 2px; margin-bottom: 16px; }
    .review-text {
      font-size: 0.95rem;
      font-weight: 400;
      color: rgba(255,255,255,0.7);
      line-height: 1.75;
      font-style: italic;
      margin-bottom: 20px;
    }
    .review-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--red);
    }
    .reviews-cta {
      text-align: center;
      margin-top: 44px;
    }
    .btn-outline-white {
      display: inline-block;
      border: 2px solid rgba(255,255,255,0.25);
      color: var(--white);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.88rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 14px 32px;
      text-decoration: none;
      transition: background 0.2s, border-color 0.2s;
    }
    .btn-outline-white:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.5); }

    /* ── SNAP FINANCE BAND ── */
    .finance-band {
      background: var(--red);
      padding: 36px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 20px;
    }
    .finance-left {}
    .finance-tag {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.65);
      margin-bottom: 6px;
    }
    .finance-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 2rem;
      font-weight: 900;
      text-transform: uppercase;
      color: var(--white);
      letter-spacing: 0.03em;
    }
    .finance-body {
      font-size: 0.92rem;
      color: rgba(255,255,255,0.75);
      margin-top: 6px;
    }
    .btn-white {
      display: inline-block;
      background: var(--white);
      color: var(--red);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 16px 36px;
      text-decoration: none;
      transition: background 0.2s;
      white-space: nowrap;
    }
    .btn-white:hover { background: #f0f0f0; }

    /* ── CONTACT ── */
    #contact { background: var(--light); }
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 60px;
      align-items: start;
    }
    .hours-block { margin-top: 32px; }
    .hours-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 12px;
    }
    .hours-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 10px 0;
      border-bottom: 1px solid rgba(0,0,0,0.07);
      font-size: 0.92rem;
    }
    .hours-day { font-weight: 600; color: var(--dark); }
    .hours-time { color: #555; }
    .hours-closed { color: var(--red) !important; font-weight: 600; }
    .contact-details { margin-top: 28px; }
    .contact-item {
      display: flex; gap: 14px; align-items: flex-start;
      margin-bottom: 20px;
    }
    .contact-icon-box {
      width: 40px; height: 40px;
      background: var(--red);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; flex-shrink: 0; color: white;
    }
    .contact-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gray);
      margin-bottom: 3px;
    }
    .contact-value {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--dark);
    }
    .contact-value a { color: var(--red); text-decoration: none; }
    .contact-value a:hover { text-decoration: underline; }

    /* Form */
    .contact-form-wrap {
      background: var(--white);
      padding: 40px;
      box-shadow: 0 4px 32px rgba(0,0,0,0.07);
    }
    .form-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.5rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--dark);
      margin-bottom: 6px;
    }
